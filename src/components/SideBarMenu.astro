---
import { configs } from "../config";
const { sideBarActiveItemID, site = "" } = Astro.props;
const prefix = site ? configs[site].path : "";
const activeClass = "bg-ac-primary/15 text-ac-primary-dark rounded-ac-md";
const homeHref = site ? prefix + "/" : "/";
---

<ul class="menu grow shrink menu-md overflow-y-auto">
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="home"
            href={homeHref}
        >
            <img src={"/nookmiles.png"} alt="" class="w-6 h-6 rounded-ac-sm" />
            首页
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="projects"
            href={prefix + "/projects"}
        >
            <img src={"/brush.png"} alt="" class="w-6 h-6 rounded-ac-sm" />
            项目
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="cv"
            href={prefix + "/cv"}
        >
            <img src={"/nookwallet.png"} alt="" class="w-6 h-6 rounded-ac-sm" />
            简历
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="blog"
            href={prefix + "/blog/"}
        >
            <img src={"/photos.png"} alt="" class="w-6 h-6 rounded-ac-sm" />
            博客
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="personal"
            href={prefix + "/personal"}
        >
            <img src={"/nookcritters.png"} alt="" class="w-6 h-6 rounded-ac-sm" />
            个人
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="notes"
            href={prefix + "/notes"}
        >
            <img src={"/drawing.png"} alt="" class="w-6 h-6 rounded-ac-sm" />
            笔记
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            href={"mailto:your@email.com"}
            target="_blank"
            referrerpolicy="no-referrer-when-downgrade"
        >
            <img src={"/messages.png"} alt="" class="w-6 h-6 rounded-ac-sm" />
            联系
        </a>
    </li>
</ul>

<script
    define:vars={{
        sideBarActiveItemID: sideBarActiveItemID,
        activeClass: activeClass,
    }}
>
    const activeItemElem = document.getElementById(sideBarActiveItemID);
    activeItemElem && activeClass.split(' ').forEach(function(c) { activeItemElem.classList.add(c); });
</script>
