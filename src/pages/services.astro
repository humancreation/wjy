---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="服务" sideBarActiveItemID="services">
    <div>
        <div class="text-3xl w-full font-bold mb-5">服务项目</div>
    </div>

    <HorizontalCard
        title="服务 1"
        img="/post_img.png"
        desc="这是第一个服务的描述内容，展示你可以提供的服务或产品。"
        badge="新"
        url="#"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="服务 2"
        img="/post_img.png"
        desc="这是第二个服务的描述内容，展示你可以提供的服务或产品。"
        url="#"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="服务 3"
        img="/post_img.png"
        desc="这是第三个服务的描述内容，展示你可以提供的服务或产品。"
        url="#"
        badge="新"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
        title="服务 4"
        img="/post_img.png"
        desc="这是第四个服务的描述内容，展示你可以提供的服务或产品。"
        url="#"
    />
</BaseLayout>
