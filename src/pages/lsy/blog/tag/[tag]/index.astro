---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import HorizontalCard from "../../../../../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../../../../../lib/createSlug";
import { configs, url as baseUrl } from "../../../../../config";

const cfg = configs.lsy;

export async function getStaticPaths() {
    const allPosts = await getCollection("blog");
    const posts = allPosts.filter((p) => p.data.site === "lsy");
    const tags = [...new Set(posts.flatMap((p) => p.data.tags || []))];
    return tags.map((tag) => ({
        params: { tag },
        props: { tag, posts: posts.filter((p) => p.data.tags?.includes(tag)) },
    }));
}

const { tag, posts } = Astro.props;
const filtered = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${cfg.AUTHOR_INITIAL} | #${tag}`} sideBarActiveItemID="blog" site="lsy">
    <div class="mb-5">
        <div class="text-3xl w-full font-bold">标签: #{tag}</div>
        <a href="/lsy/blog/" class="text-sm text-ac-primary hover:underline">&larr; 返回博客</a>
    </div>

    {
        filtered.length === 0 ? (
            <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
                <p class="font-bold">暂无文章</p>
            </div>
        ) : (
            <ul>
                {filtered.map((post) => (
                    <>
                        <HorizontalCard
                            title={post.data.title}
                            img={post.data.heroImage}
                            desc={post.data.description}
                            url={baseUrl("wjy/blog/" + createSlug(post.data.title, post.slug))}
                            target="_self"
                            badge={post.data.badge}
                            tags={post.data.tags}
                        />
                        <div class="divider my-0" />
                    </>
                ))}
            </ul>
        )
    }
</BaseLayout>

