---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import HorizontalCard from "../../../../../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../../../../../lib/createSlug";
import { configs, url as baseUrl } from "../../../../../config";

const cfg = configs.lmx;

export async function getStaticPaths() {
    const allNotes = await getCollection("notes");
    const notes = allNotes.filter((n) => n.data.site === "lmx");
    const tags = [...new Set(notes.flatMap((n) => n.data.tags || []))];
    return tags.map((tag) => ({
        params: { tag },
        props: { tag, notes: notes.filter((n) => n.data.tags?.includes(tag)) },
    }));
}

const { tag, notes } = Astro.props;
const filtered = notes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${cfg.AUTHOR_INITIAL} | #${tag}`} sideBarActiveItemID="notes" site="lmx">
    <div class="mb-5">
        <div class="text-3xl w-full font-bold">标签: #{tag}</div>
        <a href="/lmx/notes/" class="text-sm text-ac-primary hover:underline">&larr; 返回笔记</a>
    </div>

    {
        filtered.length === 0 ? (
            <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
                <p class="font-bold">暂无笔记</p>
            </div>
        ) : (
            <ul>
                {filtered.map((note) => (
                    <>
                        <HorizontalCard
                            title={note.data.title}
                            img={note.data.heroImage}
                            desc={note.data.description}
                            url={baseUrl("lmx/notes/" + createSlug(note.data.title, note.slug))}
                            target="_self"
                            badge={note.data.badge}
                            tags={note.data.tags}
                        />
                        <div class="divider my-0" />
                    </>
                ))}
            </ul>
        )
    }
</BaseLayout>
